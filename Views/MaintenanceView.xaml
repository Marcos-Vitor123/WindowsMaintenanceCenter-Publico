<UserControl x:Class="WindowsMaintenanceCenter.Views.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="560"
             Background="#f0f0f0">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,20,30,50">
        <StackPanel>
            <TextBlock Text="Manutenção" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,5"/>
            <TextBlock Text="Selecione uma opção abaixo para iniciar" FontSize="14" Foreground="#7f8c8d" Margin="0,0,0,30"/>

            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="250"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="10,10,0,0" 
                                BorderBrush="#e0e0e0" BorderThickness="1" Width="230">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                           Foreground="#2c3e50" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#7f8c8d" 
                                           TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Border Background="{Binding FrequencyColor, Converter={StaticResource HexToBrushConverter}}" CornerRadius="10" 
                                        Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Frequency}" FontSize="10" FontWeight="SemiBold" 
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding RequiresRestart, Converter={StaticResource BoolToRestartIconConverter}}" 
                                               FontSize="11" Foreground="#e74c3c" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding IsDeepClean, Converter={StaticResource BoolToDeepCleanIconConverter}}" 
                                               FontSize="11" Foreground="#e67e22" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                
                                <Button Content="Executar" Tag="{Binding Id}" 
                                        FontSize="13" FontWeight="SemiBold" Foreground="White" 
                                        Background="{Binding Id, Converter={StaticResource TaskIdToColorConverter}}"
                                        BorderThickness="0" Padding="0,10" Cursor="Hand"
                                        Margin="0,15,0,0" Width="120" HorizontalAlignment="Center"
                                        Command="{Binding DataContext.ExecuteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Id}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>