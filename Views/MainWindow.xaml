<Window x:Class="WindowsMaintenanceCenter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsMaintenanceCenter.Views"
        xmlns:vm="clr-namespace:WindowsMaintenanceCenter.ViewModels"
        mc:Ignorable="d"
        Title="Windows Maintenance Center"
        Height="550" Width="850"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/ico.ico"
        Background="#f0f0f0">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo/Title -->
                <Border Grid.Row="0" Background="#2c3e50" Padding="15,20">
                    <TextBlock Text="Windows Maintenance Center" 
                               Foreground="White" FontSize="16" FontWeight="Bold" 
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Navigation Buttons -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="5,10">
                    <StackPanel>
                        <Button Tag="🏠" Content="Início"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.Home}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                        <Button Tag="🛠" Content="Manutenção"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.Maintenance}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                        <Button Tag="📊" Content="Diagnóstico"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.Diagnostics}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                        <Button Tag="🚀" Content="Inicialização"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.Startup}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                        <Button Tag="⚙" Content="Configurações"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.Settings}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                        <Button Tag="📋" Content="Histórico"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:PageType.History}"
                                Height="50" Margin="10,5" HorizontalContentAlignment="Left" Padding="15,0"
                                FontSize="14" FontWeight="SemiBold" Foreground="#2c3e50"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Version/Footer -->
                <Border Grid.Row="2" Background="#f8f9fa" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0" Padding="10">
                    <TextBlock Text="v1.0.0" FontSize="11" Foreground="#7f8c8d" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#f0f0f0" Margin="0">
            <ContentControl Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                        <local:HomeView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:MaintenanceViewModel}">
                        <local:MaintenanceView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:DiagnosticsViewModel}">
                        <local:DiagnosticsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:StartupViewModel}">
                        <local:StartupView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                        <local:SettingsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                        <local:HistoryView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>

        <!-- Status Bar / Progress -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Bottom" 
                Background="#ecf0f1" BorderBrush="#bdc3c7" BorderThickness="0,1,0,0" 
                Height="40" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                           VerticalAlignment="Center" FontSize="12" Foreground="#2c3e50"/>
                <ProgressBar Grid.Column="1" Width="200" Height="8" 
                             Value="{Binding ProgressValue}" 
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                             VerticalAlignment="Center" Margin="20,0"/>
                <TextBlock Grid.Column="2" Text="{Binding ProgressValue, StringFormat='{}{0}%'}" 
                           VerticalAlignment="Center" FontSize="11" Foreground="#7f8c8d" Margin="10,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsRunning}" Value="True"/>
                                        <Condition Binding="{Binding IsIndeterminate}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Toast Notification Panel -->
        <Border x:Name="NotificationPanel" Grid.Column="0" Grid.ColumnSpan="2"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,10,15,0" Padding="16,12" CornerRadius="8"
                Background="#2c3e50"
                MaxWidth="350" MinWidth="250"
                Panel.ZIndex="100"
                Opacity="0" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="NotificationTitle" Text="" FontSize="13" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                <TextBlock x:Name="NotificationMessage" Text="" FontSize="12" Foreground="#bdc3c7" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>