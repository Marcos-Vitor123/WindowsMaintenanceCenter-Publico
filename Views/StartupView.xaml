    <UserControl x:Class="WindowsMaintenanceCenter.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="560"
             Background="#f0f0f0">
    
    <Grid Margin="30,20,30,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Gerenciador de Inicialização" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" VerticalAlignment="Center"/>
            <Button Content="🔄 Atualizar" Command="{Binding RefreshCommand}" 
                    FontSize="12" FontWeight="SemiBold" Foreground="#3498db" Background="Transparent"
                    BorderBrush="#3498db" BorderThickness="1" Padding="15,6" Cursor="Hand"
                    Margin="20,0,0,0" HorizontalAlignment="Right">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#e8f0fe"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#e0e0e0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Background="#f8f9fa" Margin="1,1,1,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PROGRAMA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="1" Text="EDITORA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="2" Text="IMPACTO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                </Grid>

                <!-- List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e0e0e0" BorderThickness="0,1,0,0" Margin="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding ProgramName}" 
                                                   FontSize="13" FontWeight="Medium" Foreground="#2c3e50" Padding="15,12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Publisher}" 
                                                   FontSize="12" Foreground="#7f8c8d" Padding="15,12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Impact}" 
                                                   FontSize="12" FontWeight="Medium" 
                                                   Foreground="{Binding Impact, Converter={StaticResource ImpactToColorConverter}}"
                                                   Padding="15,12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ToggleButton IsChecked="{Binding Enabled}" 
                                                          Width="50" Height="26" Margin="0,0,10,0"
                                                          Style="{StaticResource ModernToggleButton}">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="Click">
                                                        <i:InvokeCommandAction Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                               CommandParameter="{Binding}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ToggleButton>
                                            <TextBlock Text="{Binding Enabled, Converter={StaticResource BoolToEnabledTextConverter}}" 
                                                       FontSize="12" Foreground="#7f8c8d" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>