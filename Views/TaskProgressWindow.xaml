<Window x:Class="WindowsMaintenanceCenter.Views.TaskProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Executando tarefa..."
        Height="220" Width="460"
        MinHeight="220" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        Background="#f0f0f0"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="#cccccc" BorderThickness="1"
        Closing="Window_Closing">

    <Grid Margin="24" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Task icon + name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock x:Name="TaskIcon" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TaskTitle" FontSize="16" FontWeight="Bold" Foreground="#2c3e50"/>
                <TextBlock x:Name="TaskSubtitle" FontSize="11" Foreground="#7f8c8d" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Progress bar -->
        <Border Grid.Row="1" Background="#ecf0f1" CornerRadius="11" ClipToBounds="True" Margin="0,0,0,12">
            <Grid>
                <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100"
                             Value="0" Foreground="#3498db" Background="Transparent" BorderThickness="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid Background="Transparent">
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="#3498db"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock x:Name="ProgressText" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11" FontWeight="SemiBold" Foreground="#7f8c8d" Margin="0,0,8,0"/>
            </Grid>
        </Border>

        <!-- Status text -->
        <TextBlock x:Name="StatusText" Grid.Row="2" FontSize="12" FontWeight="Medium"
                   Foreground="#2c3e50" Margin="0,0,0,14" TextWrapping="Wrap"
                   Text="Preparando execução..."/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancelar" Width="110" Height="34"
                    Visibility="Visible" Cursor="Hand" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="#e74c3c" CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#c0392b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="CloseButton" Content="Fechar" Width="110" Height="34"
                    Visibility="Collapsed" Cursor="Hand" IsDefault="True" Foreground="White" FontWeight="SemiBold" FontSize="12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="#27ae60" CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#219a52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
