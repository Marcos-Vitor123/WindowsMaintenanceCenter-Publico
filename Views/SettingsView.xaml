<UserControl x:Class="WindowsMaintenanceCenter.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:WindowsMaintenanceCenter.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="560"
             Background="#f0f0f0">
    
    <UserControl.Resources>
        <conv:TaskKeyToNameConverter x:Key="TaskKeyToNameConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,20,30,50">
        <StackPanel>
            <TextBlock Text="Configurações" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,30"/>

            <!-- Geral -->
            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#e0e0e0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Geral" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox IsChecked="{Binding Config.StartWithWindows, Mode=TwoWay}" 
                                  Content="Iniciar com o Windows" FontSize="14" Foreground="#2c3e50" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox IsChecked="{Binding Config.MinimizeToTray, Mode=TwoWay}" 
                                  Content="Minimizar para a bandeja do sistema" FontSize="14" Foreground="#2c3e50" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox IsChecked="{Binding Config.OpenCentered, Mode=TwoWay}" 
                                  Content="Abrir centralizado na tela" FontSize="14" Foreground="#2c3e50" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox IsChecked="{Binding Config.ShowNotifications, Mode=TwoWay}" 
                                  Content="Mostrar notificações" FontSize="14" Foreground="#2c3e50" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Modo de Funcionamento -->
            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#e0e0e0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Modo de Funcionamento" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton Content="Modo Assistido (padrão) - O programa monitora e pergunta antes de executar"
                                     IsChecked="{Binding Config.AutoMode, Converter={StaticResource InverseBoolConverter}, Mode=TwoWay}"
                                     FontSize="14" Foreground="#2c3e50" GroupName="AutoMode" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton Content="Modo Automático - Executa automaticamente apenas tarefas seguras"
                                     IsChecked="{Binding Config.AutoMode, Mode=TwoWay}"
                                     FontSize="14" Foreground="#2c3e50" GroupName="AutoMode" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Frequência das Tarefas -->
            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#e0e0e0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Frequência das Tarefas" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,10"/>
                    <TextBlock Text="Configure a frequência de cada tarefa automática" FontSize="12" Foreground="#7f8c8d" Margin="0,0,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding Config.TaskSchedules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,15" Padding="15" Background="#f8f9fa" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Value.Enabled, Mode=TwoWay}" 
                                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Key, Converter={StaticResource TaskKeyToNameConverter}}" 
                                                       FontSize="13" FontWeight="Medium" Foreground="#2c3e50"/>
                                            <TextBlock Text="{Binding Value.Description}" FontSize="11" Foreground="#7f8c8d" TextWrapping="Wrap" MaxWidth="300"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="A cada" FontSize="12" Foreground="#7f8c8d" 
                                                   VerticalAlignment="Center" Margin="15,0,5,0"/>
                                        
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <TextBox Text="{Binding Value.IntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="50" Height="30" FontSize="13" Padding="5,3" BorderBrush="#bdc3c7" BorderThickness="1">
                                                <TextBox.Template>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                                CornerRadius="4">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </TextBox.Template>
                                            </TextBox>
                                            <TextBlock Text="dias" FontSize="12" Foreground="#7f8c8d" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Sistema -->
            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#e0e0e0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Sistema" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20"/>
                    
                    <Button Content="💾 Salvar Configurações" Command="{Binding SaveCommand}"
                            FontSize="13" FontWeight="SemiBold" Foreground="White" Background="#27ae60"
                            BorderThickness="0" Padding="30,14" Cursor="Hand"
                            HorizontalAlignment="Left" Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2ecc71"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    
                    <Button Content="🔄 Restaurar Configurações Padrão" Command="{Binding ResetDefaultsCommand}"
                            FontSize="13" FontWeight="SemiBold" Foreground="#e74c3c" Background="Transparent"
                            BorderBrush="#e74c3c" BorderThickness="1" Padding="30,14" Cursor="Hand"
                            HorizontalAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#fdf2f2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                </StackPanel>
            </Border>

            <!-- Sobre / Marca d'Água -->
            <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#e0e0e0" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Sobre" FontSize="18" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    
                    <Border Background="#2c3e50" CornerRadius="12" Padding="30,25" Margin="0,0,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Windows Maintenance Center" FontSize="20" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="v1.0.0" FontSize="14" Foreground="#bdc3c7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Autor:" FontSize="13" FontWeight="SemiBold" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="Marcos Vitor" FontSize="13" Foreground="#7f8c8d" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Versão:" FontSize="13" FontWeight="SemiBold" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="1.0.0" FontSize="13" Foreground="#7f8c8d" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Licença:" FontSize="13" FontWeight="SemiBold" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="PolyForm Noncommercial 1.0.0" FontSize="13" Foreground="#7f8c8d" Margin="10,0,0,0" TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Copyright:" FontSize="13" FontWeight="SemiBold" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="© 2026 Marcos Vitor. Todos os direitos reservados." FontSize="13" Foreground="#7f8c8d" Margin="10,0,0,0" TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="GitHub:" FontSize="13" FontWeight="SemiBold" Foreground="#2c3e50"/>
                        <TextBlock Grid.Column="1" Text="github.com/Marcos-Vitor123/WindowsMaintenanceCenter" FontSize="13" Foreground="#3498db" Margin="10,0,0,0" TextWrapping="Wrap"/>
                    </Grid>

                    <Border Background="#fdf2e8" CornerRadius="8" Padding="15" Margin="0,10,0,0" BorderBrush="#f0c27a" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚠ Uso Não Comercial" FontSize="13" FontWeight="Bold" Foreground="#e67e22" HorizontalAlignment="Center"/>
                            <TextBlock Text="Este software é distribuído sob a licença PolyForm Noncommercial. É permitido o uso livre para fins pessoais e não comerciais. A VENDA ou uso comercial deste software é PROIBIDO." 
                                       FontSize="12" Foreground="#7f8c8d" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            <TextBlock Text="© 2026 Marcos Vitor — Windows Maintenance Center™" 
                                       FontSize="11" FontWeight="SemiBold" Foreground="#2c3e50" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>