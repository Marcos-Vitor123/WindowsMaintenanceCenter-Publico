<UserControl x:Class="WindowsMaintenanceCenter.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="560"
             Background="#f0f0f0">
    
    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Histórico de Operações" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" VerticalAlignment="Center"/>
            <Button Content="🗑️ Limpar" Command="{Binding ClearCommand}" 
                    FontSize="12" FontWeight="SemiBold" Foreground="#e74c3c" Background="Transparent"
                    BorderBrush="#e74c3c" BorderThickness="1" Padding="15,6" Cursor="Hand" Margin="20,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#fadbd8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="🔄 Atualizar" Command="{Binding RefreshCommand}" 
                    FontSize="12" FontWeight="SemiBold" Foreground="#3498db" Background="Transparent"
                    BorderBrush="#3498db" BorderThickness="1" Padding="15,6" Cursor="Hand" Margin="10,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#e8f0fe"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#e0e0e0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Background="#f8f9fa" Margin="1,1,1,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="DATA/HORA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="1" Text="FUNÇÃO EXECUTADA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="2" Text="DURAÇÃO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="ESPAÇO LIBERADO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="RESULTADO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                </Grid>

                <!-- List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e0e0e0" BorderThickness="0,1,0,0" Margin="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" 
                                                   FontSize="12" Foreground="#2c3e50" Padding="15,8" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FunctionName}" 
                                                   FontSize="12" FontWeight="Medium" Foreground="#2c3e50" Padding="15,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}" 
                                                   FontSize="12" Foreground="#7f8c8d" Padding="15,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SpaceFreedBytes, Converter={StaticResource BytesToStringConverter}}" 
                                                   FontSize="12" Foreground="#7f8c8d" Padding="15,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Success, Converter={StaticResource BoolToResultIconConverter}}" FontSize="14"/>
                                            <TextBlock Text="{Binding Success, Converter={StaticResource BoolToResultTextConverter}}" 
                                                       FontSize="12" FontWeight="Medium" Foreground="{Binding Success, Converter={StaticResource BoolToResultColorConverter}}" Margin="5,0,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="5" Content="✕" 
                                                Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                FontSize="12" Foreground="#e74c3c" Background="Transparent"
                                                BorderThickness="0" Padding="5,2" Cursor="Hand"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                ToolTip="Excluir este registro">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="BtnBorder" Property="Background" Value="#fadbd8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>