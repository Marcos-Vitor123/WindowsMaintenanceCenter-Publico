<UserControl x:Class="WindowsMaintenanceCenter.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="560"
             Background="#f0f0f0">
    
    <Grid Margin="20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title + action buttons -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Histórico de Operações" FontSize="26" FontWeight="Bold" 
                       Foreground="#2c3e50" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="🧹 Limpar Tudo" Command="{Binding ClearCommand}" 
                        FontSize="11" FontWeight="SemiBold" Foreground="#7f8c8d" Background="Transparent"
                        BorderBrush="#bdc3c7" BorderThickness="1" Padding="12,5" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#ecf0f1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🔄 Atualizar" Command="{Binding RefreshCommand}" 
                        FontSize="11" FontWeight="SemiBold" Foreground="#3498db" Background="Transparent"
                        BorderBrush="#3498db" BorderThickness="1" Padding="12,5" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#e8f0fe"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Delete selected button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="🗑️ Excluir Selecionados" Command="{Binding DeleteSelectedCommand}" 
                    FontSize="12" FontWeight="SemiBold" Foreground="#e74c3c" Background="Transparent"
                    BorderBrush="#e74c3c" BorderThickness="1" Padding="15,6" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#fadbd8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#e0e0e0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Background="#f8f9fa" Margin="1,1,1,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="DATA/HORA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="2" Text="FUNÇÃO EXECUTADA" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10"/>
                    <TextBlock Grid.Column="3" Text="DURAÇÃO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="ESPAÇO LIBERADO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="RESULTADO" FontSize="11" FontWeight="Bold" Foreground="#7f8c8d" Padding="15,10" TextAlignment="Center"/>
                </Grid>

                <!-- List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HistoryItemsControl" ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e0e0e0" BorderThickness="0,1,0,0" Margin="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" 
                                                   FontSize="12" Foreground="#2c3e50" Padding="15,8" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding FunctionName}" 
                                                   FontSize="12" FontWeight="Medium" Foreground="#2c3e50" Padding="15,8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}" 
                                                   FontSize="12" Foreground="#7f8c8d" Padding="15,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding SpaceFreedBytes, Converter={StaticResource BytesToStringConverter}}" 
                                                   FontSize="12" Foreground="#7f8c8d" Padding="15,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Success, Converter={StaticResource BoolToResultIconConverter}}" FontSize="14"/>
                                            <TextBlock Text="{Binding Success, Converter={StaticResource BoolToResultTextConverter}}" 
                                                       FontSize="12" FontWeight="Medium" Foreground="{Binding Success, Converter={StaticResource BoolToResultColorConverter}}" Margin="5,0,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="6" Content="✕" 
                                                Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                FontSize="14" FontWeight="Bold" Foreground="White" Background="#e74c3c"
                                                BorderThickness="0" Padding="0" Cursor="Hand"
                                                Width="28" Height="28"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                ToolTip="Excluir este registro"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>