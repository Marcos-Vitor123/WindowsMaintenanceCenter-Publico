<Application x:Class="WindowsMaintenanceCenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WindowsMaintenanceCenter"
             xmlns:conv="clr-namespace:WindowsMaintenanceCenter.Converters"
             xmlns:views="clr-namespace:WindowsMaintenanceCenter.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BytesToStringConverter x:Key="BytesToStringConverter"/>
            <conv:ImpactToColorConverter x:Key="ImpactToColorConverter"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:TaskKeyToNameConverter x:Key="TaskKeyToNameConverter"/>
            <conv:NextMaintenanceConverter x:Key="NextMaintenanceConverter"/>
            <conv:BoolToEnabledTextConverter x:Key="BoolToEnabledTextConverter"/>
            <conv:BoolToResultConverter x:Key="BoolToResultConverter"/>
            <conv:BoolToResultColorConverter x:Key="BoolToResultColorConverter"/>
            <conv:BoolToResultIconConverter x:Key="BoolToResultIconConverter"/>
            <conv:BoolToResultTextConverter x:Key="BoolToResultTextConverter"/>
            <conv:BoolToRestartIconConverter x:Key="BoolToRestartIconConverter"/>
            <conv:BoolToDeepCleanIconConverter x:Key="BoolToDeepCleanIconConverter"/>
            <conv:TaskIdToColorConverter x:Key="TaskIdToColorConverter"/>
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <DropShadowEffect x:Key="CardShadow" 
                              BlurRadius="8" 
                              ShadowDepth="2" 
                              Direction="270" 
                              Color="#00000033"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>